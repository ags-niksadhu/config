sudo nano /etc/apache2/apache2.conf

add in above file

<Directory /var/www/html>
    Options FollowSymLinks
    AllowOverride None

    <IfModule mod_rewrite.c>
        RewriteEngine On

        # Block requests where the Host is an IP address
        RewriteCond %{HTTP_HOST} ^\d{1,3}(\.\d{1,3}){3}$ [OR]
        RewriteCond %{HTTP_HOST} ^\d+\.\d+\.\d+\.\d+$
        RewriteRule ^ - [F]
    </IfModule>
</Directory>


