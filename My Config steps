<VirtualHost *:80>

        ServerName testnftapp.com
        ServerAlias www.testnftapp.com
        ServerAdmin webmaster@localhost
        DocumentRoot /var/www/html/the-gray-bear
        Redirect permanent / https://testnftapp.com/

        ErrorLog ${APACHE_LOG_DIR}/error.log
        CustomLog ${APACHE_LOG_DIR}/access.log combined
</VirtualHost>


<VirtualHost *:443>

        Protocols h2 http/1.1
        ServerAdmin webmaster@localhost
        ServerName testnftapp.com
        ServerAlias www.testnftapp.com
        DocumentRoot /var/www/html/the-gray-bear

        ErrorLog ${APACHE_LOG_DIR}/error.log
        CustomLog ${APACHE_LOG_DIR}/access.log combined

    <FilesMatch \.php$>
        # 2.4.10+ can proxy to unix socket
         SetHandler "proxy:unix:/run/php/php7.3-fpm.sock|fcgi://localhost"
    </FilesMatch>

        SSLEngine on
        SSLCertificateFile /etc/ssl/certs/testnftapp_com.crt
        SSLCertificatekeyFile /etc/ssl/private/testnftapp_com_private.key
        SSLCACertificateFile /etc/ssl/certs/testnftapp_com_bundle.crt
        Protocols h2 http/1.1
		
</VirtualHost>



