#!/bin/bash
cd /var/www/careernavigator-backend
git fetch origin staging
LOCAL=$(git rev-parse HEAD)
REMOTE=$(git rev-parse origin/staging)

if [ "$LOCAL" != "$REMOTE" ]; then
  echo "$(date) - New changes detected, deploying..."
  git pull origin staging
  npm install --production
  pm2 restart careernavigator-backend
  echo "$(date) - Deploy done"
else
  echo "$(date) - No changes"
fi


chmod +x /var/www/careernavigator-backend/deploy.sh


